DATABASE_URL="postgresql://user:password@localhost:5432/finplan?sslmode=prefer"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optional: daily simulation quota per user (admin)
SIMULATION_DAILY_QUOTA=10
