generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Auth (NextAuth) ---
enum AccountStatus {
  ACTIVE
  STAKING
  LISTING
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String?
  name          String?
  role          UserRole      @default(USER)
  accountStatus AccountStatus @default(ACTIVE)
  balance       Float         @default(0)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts      Account[]
  sessions      Session[]
  macroSettings MacroSettings?
  assets        Asset[]
  liabilities   Liability[]
  incomes       Income[]
  expenses      Expense[]
  goals         Goal[]
  scenarios     Scenario[]
  planSnapshots PlanSnapshot[]
  simJobs       SimulationJob[]
  shareLinks    ShareLink[]
}

enum UserRole {
  USER
  CONSULTANT
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Financial profile (per user, isolated) ---
model MacroSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  baseCurrency       String   @default("RUB")
  baseInflationPct   Float    @default(4)
  incomeTaxPct       Float    @default(13)
  planHorizonYears   Int      @default(30)
  discountRatePct    Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AssetType {
  CASH
  BANK_ACCOUNT
  DEPOSIT
  BROKERAGE
  IIS
  MUTUAL_FUND
  CRYPTO
  REAL_ESTATE
  VEHICLE
  COLLECTIBLE
  OTHER
}

model Asset {
  id                    String    @id @default(cuid())
  userId                String
  name                  String
  type                  AssetType
  currentValue          Float
  currency              String    @default("RUB")
  expectedReturnPct     Float     @default(0)
  volatilityPct         Float     @default(0)
  liquidityDays         Int       @default(0)
  maintenanceCostMonthly Float    @default(0)
  dividendIncomeMonthly Float     @default(0)
  taxEffectPct          Float     @default(0)
  isRealReturn          Boolean   @default(false)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum LiabilityType {
  MORTGAGE
  CONSUMER_LOAN
  CREDIT_CARD
  AUTO_LOAN
  STUDENT_LOAN
  OTHER
}

model Liability {
  id              String        @id @default(cuid())
  userId          String
  name            String
  type            LiabilityType
  remainingBalance Float
  interestRatePct Float
  monthlyPayment  Float
  endDate         DateTime?
  currency        String        @default("RUB")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum IncomeSource {
  SALARY
  FREELANCE
  PASSIVE
  BUSINESS
  OTHER
}

enum Frequency {
  MONTHLY
  YEARLY
  ONE_TIME
}

model Income {
  id              String       @id @default(cuid())
  userId          String
  name            String
  source          IncomeSource
  amount          Float
  currency        String       @default("RUB")
  frequency       Frequency    @default(MONTHLY)
  taxRatePct      Float        @default(13)
  growthRatePct   Float        @default(0)
  startDate       DateTime?
  endDate         DateTime?
  oneTimeDate     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Expense {
  id            String    @id @default(cuid())
  userId        String
  name          String
  category      String
  amount        Float
  currency      String    @default("RUB")
  frequency     Frequency @default(MONTHLY)
  isEssential   Boolean   @default(true)
  growthRatePct Float     @default(0)
  oneTimeDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id                    String   @id @default(cuid())
  userId                String
  name                  String
  targetAmountNominal   Float
  targetDate            DateTime
  currency              String   @default("RUB")
  priority              Int      @default(1)
  allowPartialFunding   Boolean  @default(true)
  strategy              String   @default("balanced")
  linkedAssetId         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ScenarioKind {
  PREDEFINED
  CUSTOM
}

model Scenario {
  id          String       @id @default(cuid())
  userId      String
  name        String
  kind        ScenarioKind @default(CUSTOM)
  templateKey String?
  isActive    Boolean      @default(false)
  params      Json         @default("{}")
  rules       Json         @default("[]")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  simJobs SimulationJob[]

  @@index([userId])
}

model PlanSnapshot {
  id              String   @id @default(cuid())
  userId          String
  scenarioId      String?
  deterministic   Json
  cashflowMonthly Json
  netWorthMonthly Json
  computedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model SimulationJob {
  id           String    @id @default(cuid())
  userId       String
  scenarioId   String?
  status       JobStatus @default(PENDING)
  progressPct  Int       @default(0)
  numRuns      Int       @default(5000)
  stepMonths   Int       @default(1)
  params       Json      @default("{}")
  errorMessage String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario Scenario?         @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  result   SimulationResult?

  @@index([userId, status])
}

model SimulationResult {
  id              String   @id @default(cuid())
  jobId           String   @unique
  goalProbabilities Json
  wealthPercentiles Json
  samplePaths     Json
  sensitivity     Json?
  createdAt       DateTime @default(now())

  job SimulationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ShareLink {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  readOnly  Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
